############################################################
# Shared env file for local dev + multi-EC2 `docker run`
#
# Copy to: /opt/chess64/app.env
# Defaults are `localhost` for running everything on one machine.
# For multi-EC2, edit the hostnames/IPs to match your instances.
############################################################

# ---------- Frontend (public) ----------
# This is used by the backend for CORS / redirects.
FRONTEND_URL=http://localhost:5173
# Example (EC2): FRONTEND_URL=http://FRONTEND_EC2_PUBLIC_IP_OR_DOMAIN:5173

# Vite dev server reads these at startup (client container).
VITE_API_URL=http://localhost:8080
VITE_GAME_SERVER_API_URL=http://localhost:9090
VITE_STOCKFISH_SERVER_API_URL=http://localhost:8081
# Example (EC2):
# VITE_API_URL=http://BACKEND_EC2_PUBLIC_IP_OR_DOMAIN:8080
# VITE_GAME_SERVER_API_URL=http://BACKEND_EC2_PUBLIC_IP_OR_DOMAIN:9090
# VITE_STOCKFISH_SERVER_API_URL=http://BACKEND_EC2_PUBLIC_IP_OR_DOMAIN:8081

# ---------- Data stores (prefer private IP / VPC DNS) ----------
MONGODB_URL=mongodb://localhost:27017/64
REDIS_URL=redis://localhost:6379
# Example (EC2, prefer private IP / VPC DNS):
# MONGODB_URL=mongodb://DB_EC2_PRIVATE_IP_OR_DOMAIN:27017/64
# REDIS_URL=redis://DB_EC2_PRIVATE_IP_OR_DOMAIN:6379

# ---------- Auth / mail ----------
NODEMAIL_APP_PASSWORD=YOUR_NODEMAIL_APP_PASSWORD
NODEMAILER_MAIL=YOUR_NODEMAIL_EMAIL
JWT_TOKEN_SECRET=YOUR_JWT_SECRET_1
JWT_TOKEN_SIGNUP_MAIL_SECRET=YOUR_JWT_SECRET_2
JWT_RESET_PASSWORD_SECRET=YOUR_JWT_SECRET_3

# ---------- App users ----------
STOCKFISH_EMAIL=STOCKFISH_ACCOUNT_EMAIL_ID
STOCKFISH_PASSWORD=STOCKFISH_ACCOUNT_PASSWORD
